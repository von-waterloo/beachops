TG_BOT_TOKEN=

CURSOR_API_KEY=

OPENAI_API_KEY=

WHITELIST_USER_IDS=123456789

# plan + do modes; everyone else is ask-only

ADMIN_USER_IDS=123456789

DATABASE_URL=postgresql://bot:botsecret@localhost:5432/tg_cursor_bot

# Docker: compose sets postgresql://bot:...@postgres:5432/tg_cursor_bot

POSTGRES_PASSWORD=botsecret

WORKSPACE_PATH=./data/workspace

EMBEDDING_MODEL=text-embedding-3-small

MEMORY_RECALL_K=3

MEMORY_LIST_LIMIT=10

MEMORY_EMBED_MAX_CHARS=8000

CURSOR_MODEL=composer-2.5

TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

LOG_LEVEL=INFO

DEFAULT_BRANCH=dev

# Auto-attach for brand-new users only (first /start); empty = manual /repo add
DEFAULT_REPO_URL=https://github.com/stekirill/AI-ContentMaker

JOB_QUEUE_DEPTH=2

# off | preview (default) | admin — thinking in stream UI
STREAM_THINKING=preview
STREAM_THINKING_PREVIEW_CHARS=300

# photos / albums (default 20; Cursor API max 100, >20 reduces max image dimension to 2000px)
PHOTO_MAX_COUNT=20
MEDIA_GROUP_DELAY_SEC=1.0

# forwarded context batching
FORWARD_CONTEXT_TIMEOUT_SEC=15
FORWARD_CONTEXT_MAX_ITEMS=25

# Max named Cursor agent slots per user (5–10)
AGENT_SLOTS_MAX=8

