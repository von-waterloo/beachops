TG_BOT_TOKEN=

CURSOR_API_KEY=

# Второй Cursor API key (переключалка mt/mt2 в боте); пусто = переключалка скрыта
CURSOR_API_KEY_MT2=

OPENAI_API_KEY=

WHITELIST_USER_IDS=123456789

# plan + do modes; everyone else is ask-only

ADMIN_USER_IDS=123456789

# Explicit RBAC (owner > operator > viewer). Legacy lists above remain supported.
VIEWER_USER_IDS=
OPERATOR_USER_IDS=
OWNER_USER_IDS=

DATABASE_URL=postgresql://bot:botsecret@localhost:5432/tg_cursor_bot

# Redis-backed durable queue, rate limits and replay protection.
REDIS_URL=redis://localhost:6379/0

# Base64url or hex encoded 32-byte AES-256-GCM key.
DATA_ENCRYPTION_KEY=

# Strict GitHub allowlist, for example:
# {"repositories":[{"url":"https://github.com/acme/app","branches":["dev"]}]}
REPOSITORY_POLICY_JSON={"repositories":[]}

# Public HTTPS URL for Telegram Mini App (HTTP/IP is rejected by Telegram).
# Prod example: https://beachops.marketolog.tech
# Host nginx terminates TLS and proxies to webapp:8080 on the runner host.
WEBAPP_BASE_URL=
WEB_AUTH_MAX_AGE_SEC=3600
# Passkey browser session and one-time WebAuthn challenge TTLs.
WEB_SESSION_TTL_SEC=43200
WEB_AUTH_CHALLENGE_TTL_SEC=300

# GitHub (private von-waterloo/beachops; transfer to stekirill/beachops when ready).
# Token: Actions workflow_dispatch + optional PR metadata.
# Do NOT put SSH deploy keys in the bot container — deploy runs on self-hosted runner host-185.
GITHUB_TOKEN=
GITHUB_REPO=von-waterloo/beachops
# When 1/true: owner-approved deploy may call Actions workflow_dispatch (deploy-prod.yml).
GITHUB_DEPLOY_DISPATCH=0
GITHUB_DEPLOY_WORKFLOW=deploy-prod.yml
GITHUB_DEPLOY_REF=main

# Cursor agent runtime for SDK options (`cloud` | `windows`). Prod default is cloud.
DEFAULT_RUNTIME=cloud

# Shared secret for Windows worker register/heartbeat/claim (SHA-256 stored per node).
WORKER_BOOTSTRAP_TOKEN=

# WINDOWS_WORKER (notes — not part of Linux compose deploy-prod):
# - Linux prod stack (bot/worker/api/webapp) runs on host-185 via docker compose.
# - On the Windows PC: docker-compose.windows-worker.yml via scripts/install-windows-worker.ps1
#   (restart: unless-stopped; Docker Desktop AutoStart → up with the PC).
# - Env file on PC: .env.windows-worker (see .env.windows-worker.example).
# - BEACHOPS_WORKER_TOKEN = WORKER_BOOTSTRAP_TOKEN from prod .env.

# Realtime voice transcription and streaming speech.
VOICE_REALTIME_MODEL=gpt-realtime-whisper
VOICE_TTS_MODEL=gpt-4o-mini-tts
VOICE_TTS_VOICE=marin
VOICE_MAX_SESSION_SEC=300

# Signed action controls.
CALLBACK_TOKEN_TTL_SEC=600
CALLBACK_RATE_LIMIT=30
CALLBACK_RATE_WINDOW_SEC=60

# Docker: compose sets postgresql://bot:...@postgres:5432/tg_cursor_bot

POSTGRES_PASSWORD=replace-with-a-long-random-password

WORKSPACE_PATH=./data/workspace

EMBEDDING_MODEL=text-embedding-3-small

MEMORY_RECALL_K=3

MEMORY_LIST_LIMIT=10

MEMORY_EMBED_MAX_CHARS=8000

CURSOR_MODEL=composer-2.5

TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

LOG_LEVEL=INFO

DEFAULT_BRANCH=dev

# Auto-attach for brand-new users only (first /start); empty = manual /repo add
DEFAULT_REPO_URL=

JOB_QUEUE_DEPTH=2

# off | preview (default) | admin — thinking in stream UI
STREAM_THINKING=preview
STREAM_THINKING_PREVIEW_CHARS=300

# photos / albums (default 20; Cursor API max 100, >20 reduces max image dimension to 2000px)
PHOTO_MAX_COUNT=20
# Album flush delay (seconds). Use 6+ if album photos arrive >5s apart.
MEDIA_GROUP_DELAY_SEC=6.0

# Graceful shutdown: wait for active runs before closing DB (seconds).
SHUTDOWN_DRAIN_SEC=15.0
# wait after last text/photo before starting Cursor (merges caption+images that arrive separately)
PROMPT_COALESCE_SEC=5

# forwarded context batching
FORWARD_CONTEXT_TIMEOUT_SEC=25
FORWARD_CONTEXT_MAX_ITEMS=25

# Max named Cursor agent slots per user (5–10)
AGENT_SLOTS_MAX=8

# Default agent runtime for new slots/jobs: cloud | windows
DEFAULT_RUNTIME=cloud

# Bootstrap token for POST /api/workers/register (owner TMA auth also works).
# Alias: BEACHOPS_WORKER_BOOTSTRAP_TOKEN
WORKER_BOOTSTRAP_TOKEN=

