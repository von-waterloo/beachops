# BeachOps — скопируй в `.env` и заполни. Остальное уже с дефолтами в коде.
# Полный список опций: docs/CONFIGURATION.md

# --- обязательно ---

# @BotFather
TG_BOT_TOKEN=

# cursor.com/dashboard/integrations
CURSOR_API_KEY=

# голос + память
OPENAI_API_KEY=

# Ваш Telegram user id (@userinfobot). Owner = полный доступ.
OWNER_USER_IDS=123456789

# Пароль Postgres для docker compose.
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# 32 байта AES (base64url). Сгенерировать:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
DATA_ENCRYPTION_KEY=

# Какие GitHub-репо/ветки боту можно трогать.
# Пример: {"repositories":[{"url":"https://github.com/you/app","branches":["dev"]}]}
REPOSITORY_POLICY_JSON={"repositories":[]}

# --- часто нужно (раскомментируй) ---

# HTTPS Mini App — без этого /dashboard в Telegram не откроется
# WEBAPP_BASE_URL=https://beachops.example.com

# Репо для нового пользователя при /start (должно быть в policy выше)
# DEFAULT_REPO_URL=https://github.com/you/app

# Второй Cursor-ключ → переключалка mt/mt2 в боте
# CURSOR_API_KEY_MT2=

# VIEWER_USER_IDS=
# OPERATOR_USER_IDS=

# --- локальная разработка ---
# В Docker compose DATABASE_URL/REDIS_URL внутри контейнеров задаёт сам compose.

DATABASE_URL=postgresql://bot:botsecret@localhost:5433/tg_cursor_bot
REDIS_URL=redis://localhost:6379/0
