# BeachOps — скопируй в `.env` и заполни. Остальное уже с дефолтами в коде.
# Полный список опций: docs/CONFIGURATION.md

# --- обязательно ---

# @BotFather
TG_BOT_TOKEN=

# cursor.com/dashboard/integrations
CURSOR_API_KEY=

# голос + память
OPENAI_API_KEY=

# Ваш Telegram user id (@userinfobot). Owner = полный доступ.
OWNER_USER_IDS=123456789

# Пароль Postgres для docker compose.
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# 32 байта AES (base64url). Сгенерировать:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
DATA_ENCRYPTION_KEY=

# Какие GitHub-репо/ветки боту можно трогать.
# Пустой список = открытый режим: любой HTTPS GitHub URL + ветка (кроме записи в main/master).
# Пример строгого allowlist: {"repositories":[{"url":"https://github.com/you/app","branches":["dev"]}]}
REPOSITORY_POLICY_JSON={"repositories":[]}

# Самосовершенствование BeachOps (opt-in). После включения — кнопка в Mini App → Репо.
# SELF_IMPROVE_ENABLED=1
# SELF_IMPROVE_REPO_URL=https://github.com/you/beachops
# SELF_IMPROVE_BRANCHES=dev
# GITHUB_REPO=you/beachops

# --- часто нужно (раскомментируй) ---

# HTTPS Mini App — без этого /dashboard в Telegram не откроется
# WEBAPP_BASE_URL=https://beachops.example.com

# Репо для нового пользователя при /start
# DEFAULT_REPO_URL=https://github.com/you/app

# Второй Cursor-ключ → переключалка mt/mt2 в боте
# CURSOR_API_KEY_MT2=

# VIEWER_USER_IDS=
# OPERATOR_USER_IDS=

# SSH-доступ Cursor-агента к серверу для read-only docker-диагностики (docker ps/logs).
# ВНИМАНИЕ: приватный ключ передаётся в cloud-песочницу агента — операционный риск,
# осознанное отклонение от общего принципа "бот не хранит и не передаёт SSH-ключи"
# (см. docs/THREAT_MODEL.md). Заполните ВСЕ три поля, иначе фича не активируется.
# Ключ — заведите отдельную ограниченную пару, НЕ используйте существующий root/admin-ключ.
# Base64 приватного ключа:
#   python -c "import base64; print(base64.b64encode(open('id_ed25519','rb').read()).decode())"
# AGENT_SSH_HOST=
# AGENT_SSH_PORT=22
# AGENT_SSH_USER=
# AGENT_SSH_PRIVATE_KEY_B64=
# AGENT_SSH_LABEL=prod
# AGENT_SSH_REMOTE_DIR=

# --- локальная разработка ---
# В Docker compose DATABASE_URL/REDIS_URL внутри контейнеров задаёт сам compose.

DATABASE_URL=postgresql://bot:botsecret@localhost:5433/tg_cursor_bot
REDIS_URL=redis://localhost:6379/0

# --- опционально ---

# JSON-логи в stdout (bot/worker/api/windows-worker)
# LOG_LEVEL=INFO

# Cursor model по умолчанию для новых пользователей
# CURSOR_MODEL=composer-2.5

# Голос Mini App / Telegram STT (дефолты в коде)
# TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# VOICE_REALTIME_MODEL=gpt-realtime
# VOICE_TRANSCRIBE_MODEL=gpt-4o-transcribe
# VOICE_TTS_MODEL=gpt-4o-mini-tts
# VOICE_TTS_VOICE=cedar
# VOICE_MAX_SESSION_SEC=300
