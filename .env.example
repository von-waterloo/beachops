# BeachOps — скопируй в `.env` и заполни. Остальное уже с дефолтами в коде.
# Полный список опций: docs/CONFIGURATION.md

# --- обязательно ---

# @BotFather
TG_BOT_TOKEN=

# cursor.com/dashboard/integrations
CURSOR_API_KEY=

# голос + память
OPENAI_API_KEY=

# Ваш Telegram user id (@userinfobot). Owner = полный доступ.
OWNER_USER_IDS=123456789

# Пароль Postgres для docker compose.
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# 32 байта AES (base64url). Сгенерировать:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
DATA_ENCRYPTION_KEY=

# Какие GitHub-репо/ветки боту можно трогать.
# Пустой список = открытый режим: любой HTTPS GitHub URL + ветка (кроме записи в main/master).
# Пример строгого allowlist: {"repositories":[{"url":"https://github.com/you/app","branches":["dev"]}]}
REPOSITORY_POLICY_JSON={"repositories":[]}

# --- часто нужно (раскомментируй) ---

# HTTPS Mini App — без этого /dashboard в Telegram не откроется
# WEBAPP_BASE_URL=https://beachops.example.com
# Тот же host укажите в BotFather: /setdomain (нужно для Login Widget в браузере)
# TG_BOT_USERNAME=your_bot   # опционально; иначе берётся из getMe

# Репо для нового пользователя при /start
# DEFAULT_REPO_URL=https://github.com/you/app

# Второй Cursor-ключ → переключалка mt/mt2 в боте
# CURSOR_API_KEY_MT2=

# VIEWER_USER_IDS=
# OPERATOR_USER_IDS=

# --- локальная разработка ---
# В Docker compose DATABASE_URL/REDIS_URL внутри контейнеров задаёт сам compose.

DATABASE_URL=postgresql://bot:botsecret@localhost:5433/tg_cursor_bot
REDIS_URL=redis://localhost:6379/0

# --- опционально ---

# GitHub Actions: rollback / ручной dispatch. Auto-deploy = push в main после CI.
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=von-waterloo/beachops
# GITHUB_DEPLOY_DISPATCH=1
# GITHUB_DEPLOY_WORKFLOW=deploy-prod.yml
# GITHUB_DEPLOY_REF=main

# GitHub OAuth App — Mini App → Репо → «Войти через GitHub»
# Callback URL: {WEBAPP_BASE_URL}/api/auth/github/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# JSON-логи в stdout (bot/worker/api/windows-worker)
# LOG_LEVEL=INFO

# Cursor model по умолчанию для новых пользователей
# CURSOR_MODEL=composer-2.5

# Голос Mini App / Telegram STT (дефолты в коде — Dec 2025 snapshots)
# TRANSCRIBE_MODEL=gpt-4o-mini-transcribe-2025-12-15
# VOICE_REALTIME_MODEL=gpt-realtime
# VOICE_INPUT_TRANSCRIBE_MODEL=gpt-4o-transcribe
# VOICE_INPUT_TRANSCRIBE_PROMPT=
# VOICE_TTS_MODEL=gpt-4o-mini-tts-2025-12-15
# VOICE_TTS_VOICE=cedar
# VOICE_MAX_SESSION_SEC=300
# VOICE_MILESTONE_TTS=false
# VOICE_MILESTONE_MIN_INTERVAL_SEC=15
# VOICE_MILESTONE_MAX_PER_JOB=4
# AUTO_APPROVE_PLANS=false
# VOICE_REQUIRE_CONFIRM=false

# HTTP MCP для cloud-агента (SSH / docker logs на серверах владельца)
# MCP_ENABLED=true
# MCP_PUBLIC_URL=https://beachops.marketolog.tech/mcp
# MCP_BEARER_TOKEN=replace-me
# OPS_SSH_HOSTS=eu=const@185.244.49.94,ru=root@80.78.253.176
# OPS_SSH_KEY_PATH=/home/const/.ssh/id_ed25519
# OPS_SSH_TIMEOUT_SEC=30
# OPS_SSH_MAX_OUTPUT_CHARS=12000

# Самосовершенствование BeachOps (opt-in)
# SELF_IMPROVE_ENABLED=1
# SELF_IMPROVE_REPO_URL=https://github.com/<you>/beachops
# SELF_IMPROVE_BRANCHES=dev
