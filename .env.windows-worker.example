# Copy to .env.windows-worker (gitignored) on the Windows PC.
# Used by: docker compose -f docker-compose.windows-worker.yml

BEACHOPS_API_URL=https://beachops.marketolog.tech
# Same value as WORKER_BOOTSTRAP_TOKEN on prod (.env)
BEACHOPS_WORKER_TOKEN=
BEACHOPS_WORKER_HOSTNAME=
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# Optional: host folder mounted at /host-work inside the container
# BEACHOPS_HOST_WORK_ROOT=D:/Work
# BEACHOPS_LOCAL_CWD=/host-work
